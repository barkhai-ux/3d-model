# --- AI providers ---
#
# Claude: NO key needed. Uses the Claude Code login already on this machine.
#
# Local models (Ollama): NO key needed. Just run `ollama serve` and pull models,
# e.g. `ollama pull gemma2` / `ollama pull llama3.1`. They appear automatically.
# Override the host if Ollama runs elsewhere:
# OLLAMA_HOST=http://localhost:11434
#
# Google Gemini: set a key to enable the Gemini options.
# GEMINI_API_KEY=your-key-here
#
# OpenAI: set a key to enable the GPT options.
# OPENAI_API_KEY=your-key-here
#
# Optional default model for the Claude provider:
# CAD_MODEL=claude-opus-4-8
